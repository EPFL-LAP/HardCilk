HDLSTUFF_PREFIX=/opt/hdlstuff
HDLSTUFF_REPO=/repos/hdlstuff/hdlstuff
VIRTUAL_ENV=/opt/hdlstuff
SYSTEMC_HOME=/opt/hdlstuff
VERILATOR_ROOT=/opt/hdlstuff
SBT_OPTS=-Dsbt.ivy.home=/opt/hdlstuff/.ivy2 
LD_LIBRARY_PATH=/opt/hdlstuff/lib:
SYSTEMC_LIBDIR=/opt/hdlstuff/lib
SYSTEMC_INCLUDE=/opt/hdlstuff/include
PATH=/opt/hdlstuff/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin
