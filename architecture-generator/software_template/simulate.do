# This is script is to be run after running the compilation script generated by vivado, shall be run in the same directory as the compilation script
# Also take care of the path, this one is only for bfs for now. 

sccom -DMTI_BIND_SC_MEMBER_FUNCTION -DUSE_MTI_CIN -g -incr -work xil_defaultlib \
     -I ../../../../../../software/projects/bfs/include/ \
     -I ../../../../../../software/driver/include/ \
     ../../../../../../software/projects/bfs/src/questa_main.cpp \
     ../../../../../../software/driver/src/hardCilkDriver.cpp


sccom -incr -work xil_defaultlib -dpilib xil_defaultlib -link -fuse-ld=bfd

vopt -64 +acc=npr -suppress 10016 -L xil_defaultlib -L axi_infrastructure_v1_1_0 -L axi_firewall_v1_2_6 -L fifo_generator_v13_2_10 -L axi_clock_converter_v2_1_30 -L hbm_v1_0_16 -L xlconstant_v1_1_9 -L util_vector_logic_v2_0_4 -L lib_cdc_v1_0_3 -L proc_sys_reset_v5_0_15 -L smartconnect_v1_0 -L axi_register_slice_v2_1_31 -L axi_vip_v1_1_17 -L generic_baseblocks_v2_1_2 -L axi_data_fifo_v2_1_30 -L axi_protocol_converter_v2_1_31 -L blk_mem_gen_v8_4_8 -L axi_dwidth_converter_v2_1_31 -L axi_lite_ipif_v3_0_4 -L interrupt_control_v3_1_5 -L axi_gpio_v2_0_33 -L xilinx_vip -L unisims_ver -L unimacro_ver -L secureip -L xpm -work xil_defaultlib xil_defaultlib.TestBench xil_defaultlib.main_sim xil_defaultlib.glbl -o main_sim_opt


vsim -lib xil_defaultlib main_sim_opt

layout load Simulate;

view wave
view structure
view signals


do ./wave.do

radix decimal;

run -all